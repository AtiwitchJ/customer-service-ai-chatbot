############
# Database - You can change these to any PostgreSQL database that has logical replication enabled.
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
# default user is postgres


############
# Supavisor -- Database pooler
############
# Port Supavisor listens on for transaction pooling connections
POOLER_PROXY_PORT_TRANSACTION=6543
# Maximum number of PostgreSQL connections Supavisor opens per pool
POOLER_DEFAULT_POOL_SIZE=20
# Maximum number of client connections Supavisor accepts per pool
POOLER_MAX_CLIENT_CONN=100
# Unique tenant identifier
POOLER_TENANT_ID=your-tenant-id
# Pool size for internal metadata storage used by Supavisor
# This is separate from client connections and used only by Supavisor itself
POOLER_DB_POOL_SIZE=5


############
# API Proxy - Configuration for the Kong Reverse proxy.
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443


############
# API - Configuration for PostgREST.
############

PGRST_DB_SCHEMAS=public,storage,graphql_public


############
# Auth - Configuration for the GoTrue authentication server.
############

## General
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
API_EXTERNAL_URL=http://localhost:8000

## Mailer Config
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

## Email auth
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=fake_sender
ENABLE_ANONYMOUS_USERS=false

## Phone auth
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true


############
# Studio - Configuration for the Dashboard
############

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project

# replace if you intend to use Studio outside of localhost
SUPABASE_PUBLIC_URL=http://localhost:8000

# Enable webp support
IMGPROXY_ENABLE_WEBP_DETECTION=true

# Add your OpenAI API key to enable SQL Editor Assistant
OPENAI_API_KEY=


############
# Functions - Configuration for Functions
############
# NOTE: VERIFY_JWT applies to all functions. Per-function VERIFY_JWT is not supported yet.
FUNCTIONS_VERIFY_JWT=false


############
# Logs - Configuration for Analytics
# Please refer to https://supabase.com/docs/reference/self-hosting-analytics/introduction
############

# Change vector.toml sinks to reflect this change
# these cannot be the same value
LOGFLARE_PUBLIC_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-public
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-private

# Docker socket location - this value will differ depending on your OS
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

# Google Cloud Project details
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER

############
# Storage - Configuration for the storage
############

STORAGE_TENANT_ID=stub
GLOBAL_S3_BUCKET=stub
REGION=stub
S3_PROTOCOL_ACCESS_KEY_ID=625729a08b95bf1b7ff351a663f3a23c
S3_PROTOCOL_ACCESS_KEY_SECRET=850181e4652dd023b7a98c58ae0d2d34bd487ee0cc3254aed6eda37307425907

# Used in docker-compose.s3.yml for minio
MINIO_ROOT_USER=supa-storage
MINIO_ROOT_PASSWORD=secret1234

# ==========================================
# Redis
# ==========================================
REDIS_PASSWORD=your_redis_password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CHAT_DB=0
REDIS_QUEUE_DB=1
REDIS_MEMORY_DB=2
REDIS_VERIFY_DB=3
REDIS_COOLDOWN_DB=4

# ==========================================
# MongoDB
# ==========================================
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=your_mongo_root_password
MONGO_URL=mongodb://root:your_mongo_root_password@mongodb:27017/?authSource=admin
MONGO_DB=chatbot

# ==========================================
# RabbitMQ
# ==========================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ==========================================
# Ollama Configuration
# ==========================================
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.1:8b #gpt-oss:20b #gpt-oss:20b-cloud #ministral-3:3b-cloud #nemotron-3-nano:30b-cloud #qwen3-next:80b-cloud #deepseek-v3.5:14b  
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
OLLAMA_API_KEY=ollama
OLLAMA_TIMEOUT_MS=300000
OLLAMA_TAGGING_MODEL=gemma3:4b-cloud
OLLAMA_VISION_MODEL=gemma3:4b-cloud
CUDA_VISIBLE_DEVICES=0
OCR_CONCURRENCY=10

# ==========================================
# Document Processing
# ==========================================
DISABLE_DOCLING_OCR=true

# ==========================================
# Supabase Integration
# ==========================================
SUPABASE_URL=http://kong:8000
SUPABASE_KEY=${SERVICE_ROLE_KEY}

# ==========================================
# RAG / Document Processing
# ==========================================
CHUNK_SIZE=2048
CHUNK_OVERLAP=400
MAX_FILE_SIZE=500

# ==========================================
# Multimodal RAG Service
# ==========================================
MULTIMODAL_RAG_URL=http://multimodal-rag-upload:8001
RAG_SERVICE_MODE=multimodal
RAG_UPLOAD_PROXY_URL=http://multimodal-rag-upload:8001

# ==========================================
# Cache Settings
# ==========================================
CACHE_UPDATE_INTERVAL=86400000
CACHE_STARTUP_DELAY=5000
AUTO_CACHE_UPDATE=true

# ==========================================
# Health Check
# ==========================================
HEALTHCHECK_INTERVAL=30s

# ==========================================
# Debug
# ==========================================
DEBUG=

# ==========================================
# Webchat
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:80,http://localhost
AUTH_BYPASS_MODE=true
EXTERNAL_AUTH_API=http://localhost:3307/api/verify-user
MAX_LOGIN_ATTEMPTS=5
BLOCK_DURATION_MS=300000
API_BASE=http://user-backend:3001
PORT=3000
ADMIN_PORT=3002
USER_BACKEND_PORT=3001
AI_AGENT_PORT=8765
NODE_ENV=production
RATE_LIMIT_WINDOW_MS=300000
RATE_LIMIT_MAX_REQUESTS=500
REDIS_SESSION_TTL=86400
REDIS_CHAT_HISTORY_LIMIT=100
AFK_TIMEOUT_MS=300000
AFK_WARNING_MS=30000
BACKGROUND_TIMEOUT_MS=180000
WS_RECONNECT_DELAY_MS=5000
MS_FORMS_REPORT_URL=https://forms.office.com/pages/responsepage.aspx
IP_DETECTION_API=https://api.ipify.org?format=json
LOG_LEVEL=info
ENABLE_DEBUG_LOGS=false
WORKER_ERROR_NOTIFICATION=true
QUEUE_NAME=ai-agent-queue
CHAT_TTL_SECONDS=600
AGENT_WEBHOOK_URL=http://ai-agent:8765/agent
REPLY_WEBHOOK_URL=http://user-backend:3001/webhook/receive_reply

# ==========================================
# AI Agent Configuration
# ==========================================
AI_AGENT_QUEUE_NAME=ai-agent-queue
MS_FORM_QUEUE_NAME=ms_form
RESET_PASSWORD_QUEUE_NAME=reset_password
AI_AGENT_KEEP_ALIVE=30m
INTERNAL_BACKEND_URL=http://backend:3001

