# ===========================================
# Docker & Container
# ===========================================
# Local docker compose overrides (use for local development only)
docker-compose.override.yml

# Docker volumes (large data, don't commit)
volumes/
*/volumes/
**/volumes/*
# Exception: allow vector.yml to be committed (must follow volume rules)
!latte-csbot-database/volumes/
latte-csbot-database/volumes/*
!latte-csbot-database/volumes/logs/
latte-csbot-database/volumes/logs/*
!latte-csbot-database/volumes/logs/vector.yml
# Exception: allow db config files to be committed
!latte-csbot-database/volumes/db/
latte-csbot-database/volumes/db/*
!latte-csbot-database/volumes/db/data/
latte-csbot-database/volumes/db/data/*
!latte-csbot-database/volumes/db/init-scripts/
latte-csbot-database/volumes/db/init-scripts/*
!latte-csbot-database/volumes/db/migrations/
latte-csbot-database/volumes/db/migrations/*
!latte-csbot-database/volumes/db/pooler/
latte-csbot-database/volumes/db/pooler/*
# Exception: allow API and functions to be committed
!latte-csbot-database/volumes/api/
latte-csbot-database/volumes/api/*
!latte-csbot-database/volumes/functions/
latte-csbot-database/volumes/functions/*
!latte-csbot-database/volumes/snippets/
latte-csbot-database/volumes/snippets/*

# Ollama models (can be very large)
ollama_data/
.ollama/

# Supabase / Database

# Redis data
redis_data/

# MongoDB data
mongo_data/

# Cache from services
admin-backend-cache/
admin-dashboard-cache/
admin-json-data/
deno-cache/
db-config/

# Healthcheck & temp
*.pid
