# ===========================================
# latte-CSBOT-ADMIN Environment Configuration
# ===========================================
# Prerequisites:
#   - latte-csbot-database must be running first
#   - Ollama server must be accessible
#
# Usage:
#   1. Copy this file to .env
#   2. Update values as needed
#   3. Run: docker compose up -d
# ===========================================

# ==========================================
# Admin Service Ports
# ==========================================
ADMIN_PORT=3002
ADMIN_FRONTEND_PORT=81
RAG_UPLOAD_PORT=8001
DEBUG_PORT=9229

# ==========================================
# Storage Buckets
# ==========================================
FILE_RAG_BUCKET=file_rag
IMAGE_RAG_BUCKET=image_rag

# ==========================================
# Health Check Settings
# ==========================================
HEALTHCHECK_INTERVAL=30s

# ==========================================
# Supabase Keys (Required)
# ==========================================
SUPABASE_KEY=your-supabase-service-role-key
SERVICE_ROLE_KEY=your-supabase-service-role-key
JWT_SECRET=your-jwt-secret

# ==========================================
# Node Environment
# ==========================================
NODE_ENV=production

# ==========================================
# External Ollama (Required for RAG)
# Can be external server or from latte-csbot-user
# ==========================================
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
OLLAMA_TAGGING_MODEL=qwen3-vl:235b-cloud
OLLAMA_VISION_MODEL=qwen3-vl:235b-cloud
OLLAMA_API_KEY=
OLLAMA_TIMEOUT_MS=300000

# ==========================================
# Supabase Configuration (from latte-csbot-database)
# These should match the values in latte-csbot-database/.env
# ==========================================
SUPABASE_URL=http://kong:8000
SUPABASE_PUBLIC_URL=http://localhost:8000
SUPABASE_KEY=your-supabase-service-role-key
ANON_KEY=your-supabase-anon-key
SERVICE_ROLE_KEY=your-supabase-service-role-key
JWT_SECRET=your-jwt-secret

# ==========================================
# Cache Settings
# ==========================================
# Development: 300000 (5 minutes)
# Production: 86400000 (24 hours)
CACHE_UPDATE_INTERVAL=86400000
CACHE_STARTUP_DELAY=5000
AUTO_CACHE_UPDATE=true

# ==========================================
# RAG Upload Service Configuration
# ==========================================
RAG_UPLOAD_PROXY_URL=http://latte-multimodal-rag:8001
DISABLE_DOCLING_OCR=true
OCR_CONCURRENCY=5
MAX_FILE_SIZE=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
FILE_RAG_BUCKET=file_rag
IMAGE_RAG_BUCKET=image_rag

# ==========================================
# Health Check Settings
# ==========================================
HEALTHCHECK_INTERVAL=30s

# ==========================================
# Debug Settings (Development only)
# ==========================================
DEBUG=

# ==========================================
# DEPRECATED: MongoDB (No longer required)
# latte-csbot-database provides MongoDB
# ==========================================
# MONGO_URL=mongodb://root:password@mongodb:27017/?authSource=admin
# MONGO_DB=chatbot
